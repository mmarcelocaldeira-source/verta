# ═══════════════════════════════════════════════════════════
# Verta — Apache config
# ═══════════════════════════════════════════════════════════

# Default index
DirectoryIndex index.html

# ─── MIME types ─────────────────────────────────────────────
AddType video/mp4 .mp4
AddType video/webm .webm
AddType image/svg+xml .svg
AddType image/webp .webp
AddType font/woff2 .woff2
AddType font/woff .woff
AddType application/font-woff2 .woff2

<IfModule mod_rewrite.c>
    RewriteEngine On

    # ─── Force HTTPS ────────────────────────────────────────
    RewriteCond %{HTTPS} off
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # ─── Strip .html from URLs ──────────────────────────────
    # Redirect /page.html → /page
    RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
    RewriteRule ^ /%1 [R=301,L]

    # Redirect /index → /
    RewriteCond %{THE_REQUEST} \s/+index/?[\s?] [NC]
    RewriteRule ^ / [R=301,L]

    # Internally map /page → /page.html
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}.html -f
    RewriteRule ^(.+?)/?$ $1.html [L]
</IfModule>

# ─── Compression ────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

# ─── Cache headers ──────────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On

    ExpiresByType text/html "access plus 1 hour"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType image/jpeg "access plus 6 months"
    ExpiresByType image/png "access plus 6 months"
    ExpiresByType image/svg+xml "access plus 6 months"
    ExpiresByType image/webp "access plus 6 months"
    ExpiresByType video/mp4 "access plus 6 months"
    ExpiresByType video/webm "access plus 6 months"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# ─── Security headers ───────────────────────────────────────
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ─── Block access to hidden/sensitive files ────────────────
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

<FilesMatch "\.(py|md|json|lock|gitignore)$">
    Require all denied
</FilesMatch>

# ─── Custom 404 ─────────────────────────────────────────────
# ErrorDocument 404 /404.html
